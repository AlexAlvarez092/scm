        <template><![CDATA[<tr class="scm-table-column-search-row" ng-if="c.shouldShowColumnSearchRow()">
    <th ng-repeat="field in c.data.columns" ng-style="c.getColumnStyle(field)">
        <input
            ng-if="c.getColumnSearchControlType(field.name) === 'string'"
            type="text"
            class="input scm-table-column-search-input scm-table-column-search-input--text"
            ng-model="c.columnSearchTerms[field.name]"
            ng-click="$event.stopPropagation()"
            ng-keyup="c.onColumnSearchKeyUp($event)"
            ng-disabled="c.isColumnSearchDisabled(field.name)"
            ng-attr-placeholder="{{ c.isColumnSearchDisabled(field.name) ? 'Search disabled by filters' : ('Search ' + (field.label || field.name)) }}"
            aria-label="Column search"
            title="Syntax: text = starts with, =text = is, *text = contains. Press Enter to search"
        />
        <select
            ng-if="c.getColumnSearchControlType(field.name) === 'choice'"
            class="input scm-table-column-search-input scm-table-column-search-select"
            ng-class="{ 'scm-table-column-search-select--placeholder': !c.columnSearchTerms[field.name] }"
            ng-model="c.columnSearchTerms[field.name]"
            ng-change="c.onColumnSearchChange()"
            ng-click="$event.stopPropagation()"
            ng-disabled="c.isColumnSearchDisabled(field.name)"
            aria-label="Column search"
        >
            <option value="">
                {{ c.isColumnSearchDisabled(field.name) ? 'Search disabled by
                filters' : ('Select ' + (field.label || field.name)) }}
            </option>
            <option
                ng-repeat="choice in c.getColumnSearchChoiceOptions(field.name) track by choice.value"
                ng-value="choice.value"
            >
                {{ choice.label }}
            </option>
        </select>
        <div
            ng-if="c.getColumnSearchControlType(field.name) === 'reference' && !c.isColumnSearchDisabled(field.name)"
            class="scm-table-column-search-reference"
            ng-click="$event.stopPropagation()"
        >
            <scm-ref-picker
                label=""
                table="{{ c.getColumnSearchReferenceConfig(field.name).referenceTable }}"
                display-field="{{ c.getColumnSearchReferenceConfig(field.name).displayField }}"
                search-fields="{{ c.getColumnSearchReferenceConfig(field.name).searchFields || c.getColumnSearchReferenceConfig(field.name).displayField }}"
                placeholder="{{ c.isColumnSearchDisabled(field.name) ? 'Search disabled by filters' : ('Search ' + (field.label || field.name)) }}"
                reference-qualifier="{{ c.getColumnSearchReferenceConfig(field.name).referenceQualifier }}"
                page-size="{{ c.getColumnSearchReferenceConfig(field.name).pageSize }}"
                minimum-input-length="{{ c.getColumnSearchReferenceConfig(field.name).minimumInputLength || 3 }}"
                display-fields="{{ c.getColumnSearchReferenceConfig(field.name).displayFields || c.getColumnSearchReferenceConfig(field.name).displayField }}"
                order-by="{{ c.getColumnSearchReferenceConfig(field.name).orderBy }}"
                order-direction="{{ c.getColumnSearchReferenceConfig(field.name).orderDirection }}"
                ng-model="c.columnSearchTerms[field.name]"
                ng-change="c.onColumnSearchChange()"
            ></scm-ref-picker>
        </div>
        <input
            ng-if="c.getColumnSearchControlType(field.name) === 'reference' && c.isColumnSearchDisabled(field.name)"
            type="text"
            class="input scm-table-column-search-input"
            value=""
            disabled
            ng-attr-placeholder="Search disabled by filters"
            aria-label="Column search disabled"
        />
        <input
            ng-if="c.getColumnSearchControlType(field.name) === 'none'"
            type="text"
            class="input scm-table-column-search-input"
            value=""
            disabled
            ng-attr-placeholder="Search not available"
            aria-label="Column search unavailable"
        />
    </th>
</tr>
