        <template><![CDATA[<div id="pagination-wrapper">
    <sdx-button
        theme="transparent"
        icon-name="icon-rewind-filled"
        icon-size="1"
        ng-click="c.goToFirstPage()"
        ng-disabled="c.page === 1"
        title="Go to first page"
    ></sdx-button>
    <sdx-button
        theme="transparent"
        icon-name="icon-play-filled"
        icon-size="1"
        title="Go to previous page"
        ng-click="c.goToPreviousPage()"
        class="scm-go-to-previous-page"
        ng-disabled="c.page === 1"
    ></sdx-button>
    <sdx-button
        theme="transparent"
        icon-name="icon-play-filled"
        icon-size="1"
        title="Go to next page"
        ng-click="c.goToNextPage()"
        ng-disabled="c.totalPages === c.page"
    ></sdx-button>
    <sdx-button
        theme="transparent"
        icon-name="icon-forward-filled"
        icon-size="1"
        title="Go to last page"
        ng-click="c.goToLastPage()"
        ng-disabled="c.totalPages === c.page"
    ></sdx-button>
</div>

<style>
    .scm-go-to-previous-page {
        transform: scaleX(-1);
    }
</style>
]]></template>
    </sp_ng_template>
