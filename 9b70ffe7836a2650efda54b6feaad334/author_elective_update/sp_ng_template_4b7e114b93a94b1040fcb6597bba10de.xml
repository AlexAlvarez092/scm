        <template><![CDATA[<td
    ng-repeat="field in c.data.columns"
    class="scm-table-cell"
    ng-class="['scm-table-cell--' + c.getCellLayout(record, field), 'scm-table-cell--align-' + (field.align || 'left')]"
    ng-style="c.getCellStyle(field)"
>
    <a
        class="scm-table-cell-block-link"
        ng-if="c.shouldHandleRowClick(record, field, $first) && c.getRowClickAction().action.type === 'link'"
        ng-attr-href="{{ c.getRowClickHref(record) }}"
        ng-click="c.onRowClick($event, record)"
    >
        <span
            ng-repeat="block in c.getCellBlocks(record, field) track by $index"
            class="scm-table-cell-block"
            ng-class="block.className"
            ng-attr-title="{{ block.value }}"
        >
            <sdx-text-truncate>{{ block.value }}</sdx-text-truncate>
        </span>
    </a>
    <button
        type="button"
        class="scm-table-cell-block-button"
        ng-if="c.shouldHandleRowClick(record, field, $first) && c.getRowClickAction().action.type !== 'link'"
        ng-click="c.onRowClick($event, record)"
    >
        <span
            ng-repeat="block in c.getCellBlocks(record, field) track by $index"
            class="scm-table-cell-block text-truncate"
            ng-class="block.className"
            ng-attr-title="{{ block.value }}"
        >
            <sdx-text-truncate>{{ block.value }}</sdx-text-truncate>
        </span>
    </button>
    <span
        ng-if="!c.shouldHandleRowClick(record, field, $first)"
        class="scm-table-cell-block-group"
    >
        <a
            ng-repeat="block in c.getCellBlocks(record, field) track by $index"
            ng-if="c.getBlockHref(block)"
            class="scm-table-cell-block scm-table-cell-block-link text-truncate"
            ng-attr-href="{{ c.getBlockHref(block) }}"
            ng-class="block.className"
            ng-attr-title="{{ block.value }}"
        >
            <sdx-text-truncate>{{ block.value }}</sdx-text-truncate>
        </a>
        <span
            ng-repeat="block in c.getCellBlocks(record, field) track by $index"
            ng-if="!c.getBlockHref(block)"
            class="scm-table-cell-block text-truncate"
            ng-class="block.className"
            ng-attr-title="{{ block.value }}"
        >
            <sdx-text-truncate>{{ block.value }}</sdx-text-truncate>
        </span>
    </span>
</td>
<style>
    .scm-table-cell {
        vertical-align: top;
    }

    .scm-table-cell--stack .scm-table-cell-block-group,
    .scm-table-cell--stack .scm-table-cell-block-link,
    .scm-table-cell--stack .scm-table-cell-block-button {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        width: 100%;
        text-decoration: none;
        color: inherit;
        white-space: normal;
    }

    .scm-table-cell--inline .scm-table-cell-block-group,
    .scm-table-cell--inline .scm-table-cell-block-link,
    .scm-table-cell--inline .scm-table-cell-block-button {
        display: flex;
        flex-direction: row;
        align-items: center;
        flex-wrap: wrap;
        gap: var(--scm-spacing-1);
    }

    .scm-table-cell-block,
    .scm-table-cell-block-group {
        display: block;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        width: 100%;
    }

    .scm-table-cell-block-group .scm-table-cell-block {
        width: auto;
    }

    .scm-table-cell-block-link {
        text-decoration: none;
        color: inherit;
    }

    .scm-table-cell-block-button {
        border: 0;
        background: transparent;
        padding: 0;
        margin: 0;
        text-align: left;
        color: inherit;
        font: inherit;
        cursor: pointer;
    }

