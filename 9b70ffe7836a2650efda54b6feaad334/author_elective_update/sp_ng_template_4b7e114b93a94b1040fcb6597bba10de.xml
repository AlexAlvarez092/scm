    .scm-table-cell--align-right .scm-table-cell-block-button {
        align-items: flex-end;
    }

    .scm-table-cell--align-right .scm-table-cell-block {
        text-align: right;
    }

    .scm-table-cell--align-center .scm-table-cell-block-group,
    .scm-table-cell--align-center .scm-table-cell-block-link,
    .scm-table-cell--align-center .scm-table-cell-block-button {
        align-items: center;
    }

    .scm-table-cell--align-center .scm-table-cell-block {
        text-align: center;
    }
</style>
]]></template>
