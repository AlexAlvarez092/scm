        <template><![CDATA[<sdx-dialog
    label="Save current filter"
    id="{{c.saveFilterDialogId}}"
    class="align-header-center"
>
    <sdx-dialog-toggle>
        <sdx-icon
            icon-name="icon-save"
            size="1"
            id="scm-table-save-filter-icon"
            title="Save current filter"
            ng-click="c.onOpenSaveFilterDialog()"
        ></sdx-icon>
    </sdx-dialog-toggle>
    <sdx-dialog-content>
        <div class="scm-save-filter-dialog-form">
            <sdx-input
                type="text"
                label="Filter name"
                placeholder="Enter a name for this filter"
                change-callback="sdxInputHandler(this)"
                scm-model-provider
                ng-model="c.saveFilterName"
                ng-value="c.saveFilterName"
            ></sdx-input>
            <p
                class="scm-save-filter-dialog-error"
                ng-if="c.saveFilterError"
                ng-bind="c.saveFilterError"
            ></p>
            <div class="scm-save-filter-dialog-actions">
                <sdx-button
                    theme="transparent"
                    icon-name="icon-close"
                    icon-size="2"
                    label="Cancel"
                    ng-click="c.closeDialogById(c.saveFilterDialogId)"
                    ng-disabled="c.savingFilter"
                ></sdx-button>
                <sdx-button
                    theme="transparent"
                    icon-name="icon-check-mark"
                    icon-size="2"
                    label="Save"
                    ng-click="c.confirmSaveFilter()"
                    ng-disabled="!c.saveFilterName || !c.saveFilterName.trim() || c.savingFilter"
                ></sdx-button>
            </div>
        </div>
    </sdx-dialog-content>
</sdx-dialog>

<style>
    .scm-save-filter-dialog-form {
        width: 360px;
        display: flex;
        flex-direction: column;
        gap: var(--scm-spacing-3);
    }

    .scm-save-filter-dialog-actions {
        display: flex;
        justify-content: flex-end;
        gap: var(--scm-spacing-2);
    }

    .scm-save-filter-dialog-error {
        margin: 0;
        color: var(--sdx-color-functional-error, #c00);
        font-size: var(--scm-font-size-small);
    }
</style>
]]></template>
    </sp_ng_template>
</record_update>
