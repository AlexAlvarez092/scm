        <template><![CDATA[<sdx-dialog
    label="Saved filters"
    id="{{c.bookmarksDialogId}}"
    class="align-header-center"
>
    <sdx-dialog-toggle>
        <sdx-icon
            icon-name="icon-star"
            size="1"
            id="scm-table-bookmarks-icon"
            title="Saved filters"
            ng-click="c.onOpenBookmarksDialog()"
        ></sdx-icon>
    </sdx-dialog-toggle>
    <sdx-dialog-content>
        <div class="scm-bookmarks-dialog-container">
            <p
                class="scm-bookmarks-dialog-empty"
                ng-if="!c.savedFilters || !c.savedFilters.length"
                ng-bind="'No saved filters yet.'"
            ></p>
            <ul
                class="scm-bookmarks-dialog-list"
                ng-if="c.savedFilters && c.savedFilters.length"
            >
                <li
                    class="scm-bookmarks-dialog-item"
                    ng-repeat="filter in c.savedFilters track by filter.id"
                >
                    <sdx-icon
                        icon-name="{{ filter.isDefault ? 'icon-favorite-active' : 'icon-favorite' }}"
                        size="1"
                        class="scm-bookmarks-dialog-default-icon"
                        ng-class="{ 'scm-bookmarks-dialog-default-icon--active': filter.isDefault }"
                        title="{{ filter.isDefault ? 'Remove as default filter' : 'Set as default filter' }}"
                        ng-click="c.toggleDefaultFilter(filter); $event.stopPropagation()"
                    ></sdx-icon>
                    <button
                        type="button"
                        class="scm-bookmarks-dialog-item-name"
                        title="Apply filter"
                        ng-bind="filter.name"
                        ng-click="c.applySavedFilter(filter)"
                    ></button>
                    <sdx-icon
                        icon-name="icon-close"
                        size="1"
                        class="scm-bookmarks-dialog-delete-icon"
                        title="Delete saved filter"
                        ng-click="c.deleteSavedFilter(filter); $event.stopPropagation()"
                    ></sdx-icon>
                </li>
            </ul>
        </div>
    </sdx-dialog-content>
</sdx-dialog>

<style>
    .scm-bookmarks-dialog-container {
        min-width: 320px;
        max-width: 480px;
    }

    .scm-bookmarks-dialog-empty {
        color: var(--scm-color-gray-shade-6, #666);
        font-size: var(--scm-font-size-small);
        margin: 0;
        padding: var(--scm-spacing-2) 0;
    }

    .scm-bookmarks-dialog-list {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: var(--scm-spacing-1);
    }

    .scm-bookmarks-dialog-item {
        display: flex;
        align-items: center;
        gap: var(--scm-spacing-2);
        padding: var(--scm-spacing-1) var(--scm-spacing-2);
        border-radius: 4px;
        transition: background-color 0.15s ease;
    }

    .scm-bookmarks-dialog-item:hover {
        background-color: var(--scm-color-gray-shade-1, #f5f5f5);
    }

    .scm-bookmarks-dialog-default-icon {
        cursor: pointer;
        color: var(--scm-color-gray-shade-5, #999);
        flex-shrink: 0;
    }

    .scm-bookmarks-dialog-default-icon--active {
        color: var(--sdx-color-int-yellow, #f5a623);
    }

    .scm-bookmarks-dialog-item-name {
        flex: 1;
        background: none;
        border: none;
        padding: 0;
        text-align: left;
        cursor: pointer;
        font-size: var(--scm-font-size-base);
        color: inherit;
    }

    .scm-bookmarks-dialog-item-name:hover {
        text-decoration: underline;
    }

    .scm-bookmarks-dialog-delete-icon {
        cursor: pointer;
        color: var(--scm-color-gray-shade-5, #999);
        flex-shrink: 0;
        opacity: 0;
        transition: opacity 0.15s ease;
    }

    .scm-bookmarks-dialog-item:hover .scm-bookmarks-dialog-delete-icon {
        opacity: 1;
    }
</style>
]]></template>
    </sp_ng_template>
</record_update>
