        <template><![CDATA[<sdx-dialog
    label="Filter records"
    id="{{c.filtersDialogId}}"
    class="align-header-center"
>
    <sdx-dialog-toggle>
        <sdx-icon
            icon-name="icon-filter"
            size="1"
            id="scm-table-filters-icon"
            title="Apply filters to the table"
            ng-disabled="!data.canApplyFilters"
        ></sdx-icon>
    </sdx-dialog-toggle>
    <sdx-dialog-content>
        <div class="scm-filters-dialog-form">
            <div
                class="scm-filters-field-dialog margin-bottom-1"
                ng-repeat="filter in c.filters"
            >
                <div ng-if="filter.type === 'choice'">
                    <label
                        for="{{filter.id}}"
                        class="scm-filter-dialog-choice-field-label"
                        ng-bind="filter.label"
                    ></label>
                    <select
                        id="{{filter.id}}"
                        ng-model="filter.value"
                        class="scm-filter-dialog-choice-field-input"
                        ng-disabled="filter.loading"
                    >
                        <option
                            value=""
                            ng-if="!filter.loading"
                            ng-bind="'-- Select ' + filter.label + ' --'"
                        ></option>
                        <option
                            value=""
                            ng-if="filter.loading"
                            ng-bind="'-- Loading options... --'"
                        ></option>
                        <option
                            ng-repeat="choice in filter.choiceValues"
                            value="{{choice.value}}"
                            ng-bind="choice.label"
                        ></option>
                    </select>
                    <sdx-loading-spinner
                        ng-if="filter.loading"
                        class="scm-filter-dialog-choice-field-loading-spinner"
                    ></sdx-loading-spinner>
                </div>
                <div
                    ng-if="filter.type === 'reference'"
                    class="scm-filter-dialog-reference-field-container"
                >
                    <scm-ref-picker
                        label="{{filter.label}}"
                        table="{{filter.referenceTable}}"
                        display-field="{{filter.displayField}}"
                        search-fields="{{filter.searchFields}}"
                        placeholder="{{filter.placeholder}}"
                        reference-qualifier="{{filter.referenceQualifier}}"
                        page-size="{{filter.pageSize}}"
                        minimum-input-length="{{filter.minimumInputLength}}"
                        display-fields="{{filter.displayFields}}"
                        order-by="{{filter.orderBy}}"
                        order-direction="{{filter.orderDirection}}"
                        ng-model="filter.value"
                    ></scm-ref-picker>
                </div>
            </div>
        </div>
        <div class="scm-filter-dialog-actions-container">
            <sdx-button
                theme="transparent"
                icon-name="icon-reply-message"
                icon-size="2"
                ng-click="c.removeAllFilters()"
                label="Remove all filters"
            ></sdx-button>
            <div class="scm-filter-dialog-actions-container-save-cancel-group">
                <sdx-button
                    id="scm-table-filters-cancel"
                    theme="transparent"
                    icon-name="icon-close"
                    icon-size="2"
                    ng-click="c.cancelFilters()"
                    label="Cancel"
                ></sdx-button>
                <sdx-button
                    theme="transparent"
                    icon-name="icon-save"
                    icon-size="2"
                    ng-click="c.applyFilters()"
                    label="Save"
                ></sdx-button>
            </div>
        </div>
    </sdx-dialog-content>
</sdx-dialog>

<style>
    .scm-filters-dialog-form {
        margin-bottom: var(--scm-spacing-3);
        width: 50vw;
        min-height: 50vh;
    }

    .scm-filter-dialog-field {
        margin-bottom: var(--scm-spacing-2);
    }

    .scm-filter-dialog-choice-field-label {
        font-weight: var(--scm-font-weight-regular);
        font-size: var(--scm-font-size-medium);
        color: var(--scm-color-gray-tint-4);
        margin-bottom: var(--scm-spacing-1);
        display: block;
    }

    .scm-filter-dialog-choice-field-input {
        width: 100%;
        padding: var(--scm-padding-2);
        border: var(--scm-border-width-thin) var(--scm-border-style-default)
            var(--scm-color-gray-tint-4);
        border-radius: 5px;
        font-size: var(--scm-font-size-medium);
    }

    .scm-filter-dialog-choice-field-loading-spinner {
        display: inline-block;
        margin-left: 8px;
        margin-top: 8px;
    }

    .scm-filter-dialog-reference-field-container {
        margin-bottom: var(--scm-spacing-2);
    }

    .scm-filter-dialog-actions-container {
        display: flex;
        flex-direction: row;
        align-items: center;
        justify-content: space-between;
        margin-top: var(--scm-spacing-3);
    }

    .scm-filter-dialog-actions-container-save-cancel-group {
        display: flex;
        flex-direction: row;
        align-items: center;
        gap: var(--scm-spacing-2);
    }
</style>
]]></template>
    </sp_ng_template>
</record_update>
