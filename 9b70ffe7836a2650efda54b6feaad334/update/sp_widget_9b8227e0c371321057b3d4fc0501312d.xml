    c.breadcrumbs = [];

    c.breadcrumbs.push({ text: "Home", link: "/", icon: "icon-home" });

    $scope.$on("scm-navigation-breadcrumbs_set", function (event, breadcrumbs) {
        c.breadcrumbs = breadcrumbs;
    });
};
